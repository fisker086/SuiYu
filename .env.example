# 说明：完整列表见 README.md；仅 Docker 部署见 DOCKER-COMPOSE.md。
# 复制为 .env 后填写；本地进程 godotenv 不会覆盖已在 shell 中 export 的变量。

# Server
SERVER_PORT=8080

# Logging (slog): LOG_LEVEL=debug|info|warn|error  LOG_FORMAT=text|json
# LOG_LEVEL=info
# LOG_FORMAT=text

# LLM - OpenAI Compatible
MODEL_TYPE=openai
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_BY_AZURE=false

# LLM - Volcengine Ark (alternative)
# MODEL_TYPE=ark
# ARK_API_KEY=
# ARK_MODEL=
# ARK_BASE_URL=

# Embedding (used by long-term memory when MEMORY_PROVIDER=pgvector)
EMBEDDING_API_KEY=
EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_BASE_URL=https://api.openai.com/v1
EMBEDDING_DIMENSION=1536

# Long-term memory: pgvector = embedding + PostgreSQL agent_memory | none = disable
# Chat history (GET /chat/sessions/:id/messages) uses the same agent_memory table. Without EMBEDDING_API_KEY,
# turns are still stored with zero vectors so the list API works; with embeddings, recall quality is better.
# Swap implementation later by adding a new memory.Provider and switching MEMORY_PROVIDER.
# MEMORY_PROVIDER=pgvector
# MEMORY_RETRIEVE_TOP_K=8

# Database (PostgreSQL + pgvector)
# Docker Compose 默认启动内置 postgres：可不填 DATABASE_URL（默认连 postgres:5432，库名 sya）。
# app 与 compose 内置 postgres 同网络时主机名须为 postgres（不要用 docker0 的 172.17.x，容器内会卡住或超时）。
# 使用本机/外部已有 Postgres 时填写，例如：postgres://postgres:postgres@host.docker.internal:5432/sya?sslmode=disable
# 库在 URL 路径里；若不存在，应用启动时会尝试 CREATE DATABASE（需账号权限）。Compose 首次初始化卷时也会按 POSTGRES_DB 建库。
DATABASE_URL=

# JWT Auth
JWT_SECRET_KEY=EIeOsy5W7cbdhlQGBmCsbhTDphjUlAisxoGmnThziuA=

# Auth type: password | lark | dingtalk | wecom | telegram (SSO login). Default: password
# AUTH_TYPE=password

# --- SSO / OAuth (when AUTH_TYPE is lark | dingtalk | wecom | telegram) ---
# Same variable names for every platform; only AUTH_TYPE selects which IdP implementation runs.
# Redirect URL in the vendor console must match SSO_REDIRECT_URI exactly, e.g. Lark:
#   https://<api-host>/api/v1/auth/sso/lark/callback
# SSO_APP_ID=
# SSO_APP_SECRET=
# SSO_REDIRECT_URI=https://localhost:8080/api/v1/auth/sso/lark/callback
# IdP API base (optional). 飞书国内可不填，客户端默认 https://open.feishu.cn/open-apis；国际 Lark 示例：
# SSO_OPEN_API_BASE=https://open.larksuite.com/open-apis
# After OAuth, browser redirects here with ?access_token=&refresh_token=&token_type=bearer&expires_in=
# SSO_OAUTH_SUCCESS_REDIRECT=http://localhost:5173/login
# Optional cookie Domain for OAuth state (cross-subdomain)
# SSO_COOKIE_DOMAIN=
# If true, only existing users (by email) or SSO_ADMIN_EMAILS may log in
# SSO_AUTH_ENFORCE_WHITELIST=false
# Comma-separated emails that receive is_admin on first SSO login
# SSO_ADMIN_EMAILS=

# Login captcha (4-digit SVG). Set true only for local automation — never in production.
# DISABLE_LOGIN_CAPTCHA=false

# Langfuse (observability)
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=https://cloud.langfuse.com

# Skills
SKILLS_DIR=./skills

# Default admin when DB has no users (empty DB only). Required for SeedDefaultAdmin; compose 默认 changeme，生产请改掉。
ADMIN_DEFAULT_PASSWORD=
# Comma-separated usernames (not emails). Empty DB: seed creates them as admin. Non-empty DB: each startup sets is_admin for matching usernames.
ADMIN_WHITELIST=

# Sandbox (code execution)
# Type: docker | kubernetes | none (default: docker)
SANDBOX_TYPE=docker
# JSON map of language to docker image
SANDBOX_DOCKER_IMAGES={"python": "python:3.11-slim", "javascript": "node:22-slim", "shell": "bash:latest"}
# Timeout in seconds (default: 30)
SANDBOX_TIMEOUT_SECONDS=30
# Memory limit in MB (default: 256)
SANDBOX_MEMORY_LIMIT_MB=256
# CPU limit percent (default: 50)
SANDBOX_CPU_PERCENT=50
